{
  "name": "data_ingestion",
  "description": "New data ingestion workflow. Archive → detect → confirm → exclude → ingest → validate.",
  "nodes": [
    {
      "id": "archive_original",
      "description": "Archive original file to {P}/vault/originals/",
      "depends_on": [],
      "required": true,
      "required_outputs": [
        {"path_contains": "vault/originals/", "description": "file archived to vault/originals/"}
      ],
      "enforce_required_outputs": true,
      "validator": null,
      "validator_params": {}
    },
    {
      "id": "detect_structure",
      "description": "Detect file structure: columns, encoding, row count, data types",
      "depends_on": ["archive_original"],
      "required": true,
      "required_outputs": [],
      "validator": null,
      "validator_params": {}
    },
    {
      "id": "confirm_with_user",
      "description": "Present structure findings and column mappings to user for confirmation. Read checklist and report responses.",
      "depends_on": ["detect_structure"],
      "required": true,
      "required_outputs": [],
      "validator": "check_checklist",
      "validator_params": {}
    },
    {
      "id": "apply_exclusions",
      "description": "Apply data exclusion rules if needed (exclusion is project-specific, not at ingestion time)",
      "depends_on": ["confirm_with_user"],
      "required": true,
      "required_outputs": [],
      "validator": "check_exclusion",
      "validator_params": {
        "excluded_prefixes": [],
        "scope": "current_batch"
      }
    },
    {
      "id": "ingest_to_db",
      "description": "Ingest cleaned data into SQLite database with source tracking",
      "depends_on": ["apply_exclusions"],
      "required": true,
      "required_outputs": [
        {"path_contains": "workspace/db/", "description": "SQLite DB updated"}
      ],
      "enforce_required_outputs": true,
      "validator": null,
      "validator_params": {}
    },
    {
      "id": "generate_schema_cache",
      "description": "Regenerate SCHEMA_{db}.md after DB changes so AI always has up-to-date table/column names. Run: python shared/tools/db_schema.py generate <db_path>",
      "depends_on": ["ingest_to_db"],
      "required": true,
      "required_outputs": [
        {"path_contains": "SCHEMA_", "description": "SCHEMA_{db}.md regenerated"}
      ],
      "enforce_required_outputs": true,
      "validator": null,
      "validator_params": {}
    },
    {
      "id": "post_validation",
      "description": "Validate ingested data quality. Read checklist, run each check, report results in checklist_responses.",
      "depends_on": ["generate_schema_cache"],
      "required": true,
      "required_outputs": [],
      "validator": ["check_checklist", "check_traceability"],
      "validator_params": {}
    }
  ]
}
