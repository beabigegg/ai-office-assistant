# ============================================================
# AI Office Assistant - .gitignore
# 原則：追蹤「框架」，忽略「資料、知識、更版紀錄」
# ============================================================

# === 機密 ===
.env
.env.local
.env.*.local
MASTER_API_KEY.txt
.mcp.json

# === 資料庫 ===
*.db
*.sqlite
*.sqlite3
*.db.bak*
*.db-journal
*.db-wal
*.db-shm

# === 大型 / 二進位資料檔 ===
*.xlsx
*.xls
*.csv
*.pdf
*.pptx
*.docx

# === 專案資料（只追蹤 _template）===
projects/*/
!projects/_template/

# === 共用知識庫（領域知識，本機累積）===
shared/kb/*.md
shared/kb/dynamic/
shared/kb/external/
shared/kb/memory/
shared/kb/knowledge_graph/
shared/kb/ops_log/
shared/kb/_backup/
shared/kb/evolution_proposals/

# === Skills 內容（領域知識）===
.claude/skills/*/
!.claude/skills/_skill_template/
!.claude/skills/.gitkeep

# === Skills-on-demand 內容 ===
.claude/skills-on-demand/*/
!.claude/skills-on-demand/.gitkeep

# === Legacy（只留本機，不追蹤）===
.claude/agents-legacy/
.claude/protocols-legacy/
shared/workflows/coordinator_legacy.py

# === 個人/客戶專屬工具（只留本機）===
shared/tools/marp_*
shared/tools/marp_themes/
shared/tools/*panjit*
shared/tools/*_customer_*

# === 更版紀錄（用 git commit 取代，本機可保留）===
CHANGELOG.md
VERSION
EVOLUTION.md
evolution_log.md

# === Claude Code 個人設定 ===
.claude/agent-memory/
.claude/settings.local.json
.claude/*.backup.md

# === Python artifacts ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# === Conda / venv ===
.conda/
.venv/
venv/
env/
requirements-lock.txt

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === Playwright MCP cache ===
.playwright-mcp/

# === Backup / Temp ===
*.backup
*.bak
*.tmp
*.temp

# === Workflow runtime state ===
shared/workflows/state/
