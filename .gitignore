# ============================================================
# AI Office Assistant - .gitignore
# 原則：追蹤「框架」，忽略「資料、知識、更版紀錄」
# ============================================================

# === 機密 ===
.env
.env.local
.env.*.local
MASTER_API_KEY.txt
.mcp.json

# === 資料庫 ===
*.db
*.sqlite
*.sqlite3
*.db.bak*
*.db-journal
*.db-wal
*.db-shm

# === 大型 / 二進位資料檔 ===
*.xlsx
*.xls
*.csv
*.pdf
*.pptx
*.docx

# === 專案資料（只追蹤 _template）===
projects/*/
!projects/_template/

# === 共用知識庫（領域知識，本機累積）===
shared/kb/*.md
shared/kb/dynamic/
shared/kb/external/
shared/kb/memory/
shared/kb/knowledge_graph/
shared/kb/ops_log/
shared/kb/_backup/
shared/kb/evolution_proposals/

# === Skills 內容（領域知識）===
.claude/skills/*/
!.claude/skills/_skill_template/
!.claude/skills/.gitkeep

# === Skills-on-demand 內容 ===
# SKILL.md 目前多數仍已納入版本控管；.skill.yaml 只追蹤通用能力型 skill。
# 帶有客戶/公司/專案業務知識的 skill metadata 維持本機，避免誤推。
.claude/skills-on-demand/mil-std-750/
.claude/skills-on-demand/graph-rag/
.claude/skills-on-demand/mes-report/
.claude/skills-on-demand/questionnaire-response/
.claude/skills-on-demand/bom-rules/
.claude/skills-on-demand/package-code/
.claude/skills-on-demand/process-bom-semantics/
.claude/skills-on-demand/reliability-testing/
.claude/skills-on-demand/internal-reliability-practice/
.claude/skills-on-demand/plm-pdf-ingestion/
.claude/skills-on-demand/pptx-template/
.claude/skills-on-demand/*/.skill.yaml
!.claude/skills-on-demand/excel-operations/.skill.yaml
!.claude/skills-on-demand/word-operations/.skill.yaml
!.claude/skills-on-demand/pptx-operations/.skill.yaml
!.claude/skills-on-demand/sqlite-operations/.skill.yaml
!.claude/skills-on-demand/marp-pptx/.skill.yaml
!.claude/skills-on-demand/xlsx-authoring/.skill.yaml
!.claude/skills-on-demand/docx-authoring/.skill.yaml
!.claude/skills-on-demand/pdf/.skill.yaml
!.claude/skills-on-demand/skill-creator/.skill.yaml
!.claude/skills-on-demand/pptx-authoring/.skill.yaml
!.claude/skills-on-demand/batch-refactor/.skill.yaml
!.claude/skills-on-demand/automotive-reliability-standards/
!.claude/skills-on-demand/automotive-reliability-standards/SKILL.md
!.claude/skills-on-demand/automotive-reliability-standards/.skill.yaml
!.claude/skills-on-demand/.gitkeep
!/.claude/skills-on-demand/excel-operations/
!/.claude/skills-on-demand/word-operations/
!/.claude/skills-on-demand/pptx-operations/
!/.claude/skills-on-demand/sqlite-operations/
!/.claude/skills-on-demand/marp-pptx/
!/.claude/skills-on-demand/xlsx-authoring/
!/.claude/skills-on-demand/docx-authoring/
!/.claude/skills-on-demand/pdf/
!/.claude/skills-on-demand/skill-creator/
!/.claude/skills-on-demand/pptx-authoring/
!/.claude/skills-on-demand/batch-refactor/
!/.claude/skills-on-demand/_skill_template/

# === Internal agents（公司內部流程/知識，不追蹤）===
.claude/agents/questionnaire-response-drafter.md
.claude/agents/report-builder.md
.claude/agents/promoter.md
.claude/agents/ingest-archiver.md
.claude/agents/ingest-structure-detector.md
.claude/agents/bom-ingest-exclusion-applier.md
.claude/agents/ingest-db-writer.md
.claude/agents/ingest-validator.md

# === Legacy（只留本機，不追蹤）===
.claude/agents-legacy/
.claude/protocols-legacy/
shared/workflows/coordinator_legacy.py

# === 個人/客戶專屬工具（只留本機）===
shared/tools/marp_*
shared/tools/marp_themes/
shared/tools/*panjit*
shared/tools/*_customer_*

# === 更版紀錄（用 git commit 取代，本機可保留）===
CHANGELOG.md
VERSION
EVOLUTION.md
evolution_log.md

# === Claude Code 個人設定 ===
.claude/agent-memory/
.claude/settings.local.json
.claude/*.backup.md

# === Python artifacts ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# === Conda / venv ===
.conda/
.venv/
venv/
env/
requirements-lock.txt

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === Playwright MCP cache ===
.playwright-mcp/

# === Backup / Temp ===
*.backup
*.bak
*.tmp
*.temp
err紀錄.txt

# === Accidental local artifacts ===
ai-officeprojects_templateworkspace*

# === Workflow runtime state ===
shared/workflows/state/
